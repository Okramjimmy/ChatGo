# ChatGo Environment Variables
# Copy to .env and adjust values before use.
# All vars are prefixed with CHATGO_ and override config.yaml values.

CHATGO_CONFIG=configs/config.yaml

CHATGO_SERVER_HOST=0.0.0.0
CHATGO_SERVER_PORT=8081

CHATGO_DATABASE_HOST=localhost
CHATGO_DATABASE_PORT=5432
CHATGO_DATABASE_NAME=chatgo
CHATGO_DATABASE_USER=chatgo
CHATGO_DATABASE_PASSWORD=changeme
CHATGO_DATABASE_SSL_MODE=disable
CHATGO_DATABASE_MAX_CONNS=25
CHATGO_DATABASE_MIN_CONNS=5

CHATGO_REDIS_HOST=localhost
CHATGO_REDIS_PORT=6379
CHATGO_REDIS_PASSWORD=
CHATGO_REDIS_DB=0

CHATGO_JWT_SECRET=change-this-to-a-long-random-secret-at-least-32-chars
CHATGO_JWT_ACCESS_TOKEN_TTL=15m
CHATGO_JWT_REFRESH_TOKEN_TTL=168h

CHATGO_FILE_STORAGE_PATH=./files
CHATGO_FILE_MAX_SIZE_BYTES=104857600
CHATGO_FILE_ENABLE_VIRUS_SCAN=false

CHATGO_LOG_LEVEL=info
CHATGO_LOG_PRODUCTION=true

CHATGO_RATE_LIMIT_REQUESTS_PER_SECOND=100
CHATGO_RATE_LIMIT_BURST=200

CHATGO_MIGRATIONS_PATH=file://migrations
